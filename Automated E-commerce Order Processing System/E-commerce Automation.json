    {
      "parameters": {
        "jsCode": "// Loop over all items incoming from the Form Node\nfor (const item of $input.all()) {\n  \n  // 1. Normalize the Full Name (Trim extra spaces and split it)\n  const fullName = item.json['Full Name'] ? item.json['Full Name'].trim() : '';\n  const nameParts = fullName.split(' ');\n  const firstName = nameParts[0] || '';\n  const lastName = nameParts.slice(1).join(' ') || '';\n\n  // 2. Normalize Email Address (Convert to lowercase)\n  const email = item.json['Email Address'] ? item.json['Email Address'].toLowerCase().trim() : '';\n\n  // 3. Keep other clean data and structure the final output\n  item.json = {\n    firstName: firstName,\n    lastName: lastName,\n    fullName: fullName,\n    email: email,\n    phoneNumber: item.json['Phone Number'] || '',\n    country: item.json['Country'] || '',\n    orderTotal: Number(item.json['Order Total']) || 0, // Ensure it's a safe number\n    submittedAt: item.json['submittedAt'],\n    formMode: item.json['formMode']\n  };\n}\n\nreturn $input.all();"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
